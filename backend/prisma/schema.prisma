datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique // ADMIN, SUPPORT_EXECUTIVE, CUSTOMER
  users User[]
}

model User {
  id               String          @id @default(uuid())
  email            String          @unique
  passwordHash     String
  name             String
  phone            String?
  roleId           Int
  role             Role            @relation(fields: [roleId], references: [id])
  refreshToken     String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  orders           Order[]
  assignedRequests ReturnRequest[] @relation("AssignedTo")
  notifications    Notification[]
  comments         Comment[]
  auditLogs        AuditLog[]
  statusHistories  StatusHistory[]
}

model Product {
  id          String      @id @default(uuid())
  sku         String      @unique
  name        String
  description String?
  price       Decimal
  imageUrl    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id             String          @id @default(uuid())
  orderNumber    String          @unique
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchaseDate   DateTime
  deliveryDate   DateTime?
  status         String          // e.g., DELIVERED, SHIPPED, PROCESSING
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  orderItems     OrderItem[]
  returnRequests ReturnRequest[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  price     Decimal
}

model ReturnRequest {
  id                  String        @id @default(uuid())
  orderId             String
  order               Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerName        String
  email               String
  phone               String
  issueType           String
  issueDescription    String
  preferredResolution String
  status              String        @default("PENDING")
  assignedToId        String?
  assignedTo          User?         @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  termsAccepted       Boolean
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  images              ReturnImage[]
  statusHistory       StatusHistory[]
  comments            Comment[]
}

model ReturnImage {
  id              String        @id @default(uuid())
  returnRequestId String
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  imageUrl        String
  publicId        String?
  createdAt       DateTime      @default(now())
}

model StatusHistory {
  id              String        @id @default(uuid())
  returnRequestId String
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  status          String
  note            String?
  createdById     String
  createdBy       User          @relation(fields: [createdById], references: [id])
  createdAt       DateTime      @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Comment {
  id              String        @id @default(uuid())
  returnRequestId String
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentText     String
  isInternal      Boolean       @default(false)
  createdAt       DateTime      @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())
}
